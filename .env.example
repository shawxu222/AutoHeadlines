# Built-in profile name or path to a custom profile YAML.
XAUTOHEADLINES_PROFILE=japan-korea-scitech-zh

# Optional: keep runtime data outside the repository.
# XAUTOHEADLINES_HOME=/path/to/xautoheadlines-home
# XAUTOHEADLINES_SOURCES_FILE=/path/to/my-sources.yaml
# XAUTOHEADLINES_KEYWORDS_FILE=/path/to/my-keywords.yaml
# XAUTOHEADLINES_BROWSER_PROFILE_DIR=/path/to/browser-profiles

# Choose openai or ollama. XAutoHeadlines will not silently create demo summaries
# when the configured provider is unavailable.
LLM_PROVIDER=ollama

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=high
OPENAI_USE_RESPONSES=true

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_THINK_MODE=fast
OLLAMA_TIMEOUT_SECONDS=300

# Explicit opt-in for local formatting tests only. Never use for final output.
XAUTOHEADLINES_ALLOW_DEMO_SUMMARIES=false

REQUEST_TIMEOUT_SECONDS=20
REQUEST_DELAY_SECONDS=1.0
FETCH_LIMIT_PER_SOURCE=20
LOG_LEVEL=INFO
